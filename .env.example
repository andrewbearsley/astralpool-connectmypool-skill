# ConnectMyPool REST API code
# Found at: ConnectMyPool website > Settings > Home Automation
# Format: XXXXXX-NNNNNN
POOL_API_CODE=your_api_code_here

# ConnectMyPool web login credentials (for pH/ORP chemistry data)
# Create a dedicated account for automation - do NOT use your primary account.
# See README.md for setup instructions.
POOL_WEB_USER=your_email@example.com
POOL_WEB_PASS=your_password_here

# Optional: custom path for session cookie cache (default: ~/.pool-session-cookies)
# POOL_SESSION_FILE=/path/to/session-cookies
